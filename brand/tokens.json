{
  "$schema": "https://design-tokens.org/draft",
  "meta": {
    "name": "Forskai Studio Brand Tokens",
    "version": "1.0.0",
    "principle": "Calm research instrument. Trust over decoration. Color maps to function, never mood."
  },
  "function": {
    "create": "teal",
    "verify": "violet",
    "ready": "green",
    "review": "amber",
    "stop": "red",
    "workspace": "neutral"
  },
  "color": {
    "neutral": {
      "bg":        { "light": "#F6F6F2", "dark": "#14151F" },
      "surface":   { "light": "#FFFFFF", "dark": "#1C1E2B" },
      "surface-2": { "light": "#EFEFEA", "dark": "#242636" },
      "border":    { "light": "#E1E2DA", "dark": "#2E3042" },
      "ink":       { "light": "#1A1B2E", "dark": "#ECECF2" },
      "ink-soft":  { "light": "#4C4E66", "dark": "#B7B9C9" },
      "muted":     { "light": "#75788C", "dark": "#8A8DA0" }
    },
    "create":  { "base": { "light": "#1F726B", "dark": "#4FB3A8" }, "soft": { "light": "#E3F0EE", "dark": "#17312E" } },
    "verify":  { "base": { "light": "#5B4FA6", "dark": "#9A8CE0" }, "soft": { "light": "#ECEAF7", "dark": "#241F3D" } },
    "ready":   { "base": { "light": "#2E7D55", "dark": "#5FBF87" }, "soft": { "light": "#E2F1E8", "dark": "#143026" } },
    "review":  { "base": { "light": "#9A6700", "dark": "#D9A441" }, "soft": { "light": "#F8EFD6", "dark": "#34280F" }, "accent": { "light": "#C0892D", "dark": "#D9A441" } },
    "stop":    { "base": { "light": "#B23A3A", "dark": "#E07A74" }, "soft": { "light": "#F7E6E4", "dark": "#371B1B" } }
  },
  "radius": { "sm": "6px", "md": "10px", "lg": "14px", "pill": "999px" },
  "space":  { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px", "6": "32px", "8": "48px" },
  "shadow": {
    "card":  { "light": "0 1px 2px rgba(26,27,46,.06), 0 1px 3px rgba(26,27,46,.05)", "dark": "0 1px 2px rgba(0,0,0,.4)" },
    "panel": { "light": "0 8px 24px rgba(26,27,46,.10)", "dark": "0 8px 24px rgba(0,0,0,.5)" }
  },
  "type": {
    "heading": "\"Newsreader\", \"Source Serif 4\", Georgia, serif",
    "ui":      "\"Inter\", \"Inter Tight\", system-ui, -apple-system, sans-serif",
    "mono":    "\"IBM Plex Mono\", \"JetBrains Mono\", ui-monospace, SFMono-Regular, monospace"
  }
}
