# Base URL of the NestJS backend. Set this to run the dashboard against the API
# (posts, accounts, and AI ideas come from the server). Leave it unset to run in
# local mode: realistic sample data persisted to localStorage, no backend needed.
#
# VITE_API_URL=http://localhost:3000/api

# Bearer token for a backend that has auth enabled (server AUTH_ENABLED=true).
# Must match the server's AUTH_TOKEN. Leave unset for an open/local backend.
#
# VITE_API_TOKEN=
