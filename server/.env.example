# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
# Where to send the browser after a successful OAuth callback (optional).
# If unset, the callback returns JSON instead of redirecting.
FRONTEND_URL=http://localhost:5173

# ─── Auth ───────────────────────────────────────────────────────────────────
# Off by default (local-first): the API is open and every request is the single
# implicit local user. Set AUTH_ENABLED=true and a strong AUTH_TOKEN to require
# `Authorization: Bearer <AUTH_TOKEN>` on every route except GET /api/health.
# (If AUTH_ENABLED=true but AUTH_TOKEN is empty, auth fails SAFE and stays open
# with a startup warning.) The dashboard sends this token via VITE_API_TOKEN.
AUTH_ENABLED=false
AUTH_TOKEN=
# Identity for the shared AUTH_TOKEN / the open default (maps to ContentItem.ownerId).
AUTH_DEFAULT_USER_ID=local
# Multi-user: per-user tokens as "userId:token" pairs, comma-separated. A request's
# token resolves to that user id, scoping their content. Leave empty for single-user.
#   AUTH_TOKENS=alice:alice-secret,bob:bob-secret
AUTH_TOKENS=

# ─── Persistence ────────────────────────────────────────────────────────────
# Operational store (posts, accounts, OAuth tokens) AND vector store backend.
#   memory  → in-process, zero deps (default; good for first run / tests)
#   file    → single JSON file, zero native deps (used by the desktop app)
#   sqlite  → better-sqlite3 + sqlite-vec (single-user / self-hosted)
#   neon    → Postgres + pgvector (cloud / serverless / multi-instance)
PERSISTENCE_DRIVER=memory

# File driver (when PERSISTENCE_DRIVER=file): where the JSON store lives.
FILE_STORE_PATH=./data/store.json

# Source Inbox + Campaigns persist to durable JSON files on any non-memory
# driver. Override their paths if needed.
SOURCES_STORE_PATH=./data/sources.json
CAMPAIGNS_STORE_PATH=./data/campaigns.json

# Content items/variants + learned timing slots are durable on any non-memory
# driver too: SQLite tables when PERSISTENCE_DRIVER=sqlite (in SQLITE_PATH
# below), JSON files otherwise. Override the JSON-file paths if needed.
CONTENT_ITEMS_STORE_PATH=./data/content-items.json
CONTENT_VARIANTS_STORE_PATH=./data/content-variants.json
TIMING_STORE_PATH=./data/timing.json
PUBLISH_LOG_STORE_PATH=./data/publish-log.json
STATUS_HISTORY_STORE_PATH=./data/status-history.json
COMMENTS_STORE_PATH=./data/comments.json

# SQLite (when PERSISTENCE_DRIVER=sqlite) — one file holds the operational store,
# the vector store, and the content/timing tables.
SQLITE_PATH=./data/content-calendar.sqlite

# Neon / Postgres (when PERSISTENCE_DRIVER=neon). pgvector must be enabled:
#   CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=postgres://user:password@your-neon-host/db?sslmode=require

# ─── Obsidian vault ─────────────────────────────────────────────────────────
# Absolute path to your markdown vault. The ingestion job indexes *.md here.
# NEVER store OAuth tokens or secrets inside the vault — it is content only.
VAULT_PATH=./vault
# Watch the vault and auto-reingest on file changes (requires `chokidar`).
VAULT_WATCH=false

# ─── Embeddings ─────────────────────────────────────────────────────────────
# mock   → deterministic hash embeddings, no network (default)
# voyage → Voyage AI (Anthropic's recommended embeddings partner)
EMBEDDINGS_PROVIDER=mock
EMBEDDING_DIMENSIONS=256
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# ─── Social platform OAuth apps ─────────────────────────────────────────────
# Set a platform's client id + secret to use its REAL API; leave blank to fall
# back to the mock for that platform. See docs/PLATFORM_SETUP.md for how to
# register each app, required scopes, and App Review notes.
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_VERSION=202401
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
# Bluesky uses an app password (Settings → App Passwords), not OAuth client creds.
# Set both to enable real posting to Bluesky; otherwise it falls back to the mock.
BLUESKY_SERVICE=https://bsky.social
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
# Mastodon: a per-instance access token (Preferences → Development → New
# application). Set both to enable real posting; otherwise it falls back to mock.
MASTODON_INSTANCE=
MASTODON_ACCESS_TOKEN=

# ─── Media storage ──────────────────────────────────────────────────────────
# local → save uploads to disk, served at /uploads (default)
# s3    → upload to S3 (requires @aws-sdk/client-s3 + the S3_* vars below)
STORAGE_DRIVER=local
UPLOADS_DIR=./data/uploads
# Public base URL used to build media URLs. For REAL platform publishing this
# must be reachable by the platforms (not localhost) — use a public host or S3.
PUBLIC_BASE_URL=http://localhost:3000
S3_BUCKET=
S3_REGION=
S3_PUBLIC_BASE_URL=

# ─── AI generator (ideas, drafts, talks) ────────────────────────────────────
# mock → deterministic offline generator (default)
# llm  → use a real LLM (provider chosen by LLM_PROVIDER below)
# All LLM-backed services fall back to the deterministic local impl on any
# error, so endpoints never fail.
IDEA_GENERATOR=mock

# Which LLM backend to use when IDEA_GENERATOR=llm:
#   anthropic → Claude via @anthropic-ai/sdk (needs ANTHROPIC_API_KEY)
#   ollama    → a local model via Ollama (no API key, runs fully offline)
LLM_PROVIDER=anthropic

# Anthropic (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Ollama (when LLM_PROVIDER=ollama). Install from https://ollama.com, then
# `ollama pull llama3.1`. The model must support structured/JSON output.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Claude Code MCP is a third, code-free option: rather than wiring an SDK, drive
# this app's HTTP API from a Claude Code agent / MCP-aware client. It lives
# outside the in-process composer (no provider entry needed). See
# docs/PRODUCT_DIRECTION.md → "LLM providers".
