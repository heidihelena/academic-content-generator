# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
# Where to send the browser after a successful OAuth callback (optional).
# If unset, the callback returns JSON instead of redirecting.
FRONTEND_URL=http://localhost:5173

# ─── Persistence ────────────────────────────────────────────────────────────
# Operational store (posts, accounts, OAuth tokens) AND vector store backend.
#   memory  → in-process, zero deps (default; good for first run / tests)
#   file    → single JSON file, zero native deps (used by the desktop app)
#   sqlite  → better-sqlite3 + sqlite-vec (single-user / self-hosted)
#   neon    → Postgres + pgvector (cloud / serverless / multi-instance)
PERSISTENCE_DRIVER=memory

# File driver (when PERSISTENCE_DRIVER=file): where the JSON store lives.
FILE_STORE_PATH=./data/store.json

# SQLite (when PERSISTENCE_DRIVER=sqlite)
SQLITE_PATH=./data/content-calendar.sqlite

# Neon / Postgres (when PERSISTENCE_DRIVER=neon). pgvector must be enabled:
#   CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=postgres://user:password@your-neon-host/db?sslmode=require

# ─── Obsidian vault ─────────────────────────────────────────────────────────
# Absolute path to your markdown vault. The ingestion job indexes *.md here.
# NEVER store OAuth tokens or secrets inside the vault — it is content only.
VAULT_PATH=./vault
# Watch the vault and auto-reingest on file changes (requires `chokidar`).
VAULT_WATCH=false

# ─── Embeddings ─────────────────────────────────────────────────────────────
# mock   → deterministic hash embeddings, no network (default)
# voyage → Voyage AI (Anthropic's recommended embeddings partner)
EMBEDDINGS_PROVIDER=mock
EMBEDDING_DIMENSIONS=256
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# ─── Social platform OAuth apps ─────────────────────────────────────────────
# Set a platform's client id + secret to use its REAL API; leave blank to fall
# back to the mock for that platform. See docs/PLATFORM_SETUP.md for how to
# register each app, required scopes, and App Review notes.
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_VERSION=202401
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
# Bluesky uses an app password (Settings → App Passwords), not OAuth client creds.
# Set both to enable real posting to Bluesky; otherwise it falls back to the mock.
BLUESKY_SERVICE=https://bsky.social
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
# Mastodon: a per-instance access token (Preferences → Development → New
# application). Set both to enable real posting; otherwise it falls back to mock.
MASTODON_INSTANCE=
MASTODON_ACCESS_TOKEN=

# ─── Media storage ──────────────────────────────────────────────────────────
# local → save uploads to disk, served at /uploads (default)
# s3    → upload to S3 (requires @aws-sdk/client-s3 + the S3_* vars below)
STORAGE_DRIVER=local
UPLOADS_DIR=./data/uploads
# Public base URL used to build media URLs. For REAL platform publishing this
# must be reachable by the platforms (not localhost) — use a public host or S3.
PUBLIC_BASE_URL=http://localhost:3000
S3_BUCKET=
S3_REGION=
S3_PUBLIC_BASE_URL=

# ─── AI idea generator ──────────────────────────────────────────────────────
# mock → deterministic offline generator (default)
# llm  → Anthropic Claude via @anthropic-ai/sdk
IDEA_GENERATOR=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
